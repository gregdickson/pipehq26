---
// Hero Section — Above the Fold
// Reference: page_anatomy.md Section 2
// Goal: Grab attention, communicate core value prop, drive primary action

interface Props {
  headline: string;
  subheadline: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  headline,
  subheadline,
  ctaText = 'Get a Free Quote',
  ctaHref = '/demo',
  secondaryCtaText = 'See How It Works',
  secondaryCtaHref = '/how-it-works',
} = Astro.props;
---

<section class="relative bg-neutral-950 text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 lg:py-40">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">
        {headline}
      </h1>
      <p class="mt-6 text-lg md:text-xl text-neutral-300 max-w-2xl">
        {subheadline}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <a href={ctaHref} class="inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold text-white bg-accent rounded-lg hover:bg-accent-dark transition-colors">
          {ctaText}
        </a>
        <a href={secondaryCtaHref} class="inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold text-white border border-neutral-500 rounded-lg hover:bg-white/10 transition-colors">
          {secondaryCtaText}
        </a>
      </div>
    </div>
  </div>
</section>
