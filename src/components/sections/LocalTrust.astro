---
// Local Trust-Builder Section
// Reference: design_patterns.md - The Local Trust-Builder Section
// Goal: Build trust with a local audience
---

<section class="py-(--space-section-y) md:py-(--space-section-y-lg) bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-neutral-900">Serving Trade Businesses Across New Zealand</h2>
      <p class="mt-4 text-lg text-neutral-600">Proudly helping tradies in Auckland, Wellington, Christchurch, and beyond.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Google Map Placeholder -->
      <div class="bg-neutral-100 rounded-2xl overflow-hidden h-80 lg:h-96">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d387193.31583520076!2d174.42381350936884!3d-36.85067222234485!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6d0d47fb5d48fpd3%3A0x400ad50862b415!2sAuckland%2C%20New%20Zealand!5e0!3m2!1sen!2sus!4v1650000000000!5m2!1sen!2sus"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Service areas in New Zealand"
          class="grayscale opacity-70 hover:opacity-100 transition-opacity"
        ></iframe>
      </div>

      <!-- Trust Elements -->
      <div class="space-y-8">
        <!-- Certifications/Logos -->
        <div>
          <h3 class="text-lg font-semibold text-neutral-900 mb-4">Trusted & Certified</h3>
          <div class="flex flex-wrap gap-6 items-center opacity-60">
            <div class="h-12 w-28 bg-neutral-200 rounded flex items-center justify-center text-xs text-neutral-500">Partner</div>
            <div class="h-12 w-28 bg-neutral-200 rounded flex items-center justify-center text-xs text-neutral-500">Member</div>
            <div class="h-12 w-28 bg-neutral-200 rounded flex items-center justify-center text-xs text-neutral-500">Certified</div>
          </div>
        </div>

        <!-- Stats -->
        <div>
          <h3 class="text-lg font-semibold text-neutral-900 mb-4">By The Numbers</h3>
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center p-4 bg-neutral-50 rounded-xl">
              <p class="text-3xl font-bold text-primary">1,500+</p>
              <p class="text-sm text-neutral-600">Trade Businesses</p>
            </div>
            <div class="text-center p-4 bg-neutral-50 rounded-xl">
              <p class="text-3xl font-bold text-primary">$50M+</p>
              <p class="text-sm text-neutral-600">Quotes Sent</p>
            </div>
            <div class="text-center p-4 bg-neutral-50 rounded-xl">
              <p class="text-3xl font-bold text-primary">98%</p>
              <p class="text-sm text-neutral-600">Customer Satisfaction</p>
            </div>
            <div class="text-center p-4 bg-neutral-50 rounded-xl">
              <p class="text-3xl font-bold text-primary">24/7</p>
              <p class="text-sm text-neutral-600">Support Available</p>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div>
          <a href="/demo" class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white bg-accent rounded-lg hover:bg-accent-dark transition-colors">
            Get a Free Quote
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
