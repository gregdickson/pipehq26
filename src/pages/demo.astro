---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Book a Free Demo | PipeHQ"
  description="See PipeHQ in action. Book a free 15-minute demo and discover how AI can automate your trade business admin."
  canonicalUrl="/demo"
>
  <Header slot="header" />

  <section class="py-(--space-section-y) md:py-(--space-section-y-lg)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Left: Copy -->
        <div class="max-w-lg">
          <h1 class="text-4xl md:text-5xl font-bold text-neutral-900">See PipeHQ in Action</h1>
          <p class="mt-4 text-lg text-neutral-600">Book a free 15-minute demo. No obligation. No sales pressure. Just a quick look at how PipeHQ can help your business.</p>
          <ul class="mt-8 space-y-4">
            <li class="flex items-start gap-3">
              <svg class="h-6 w-6 text-success flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-neutral-700">See the platform customised for your trade</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-6 w-6 text-success flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-neutral-700">Get a personalised ROI estimate</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-6 w-6 text-success flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span class="text-neutral-700">No credit card required</span>
            </li>
          </ul>
        </div>

        <!-- Right: Form -->
        <div class="bg-neutral-50 rounded-2xl border border-neutral-200 p-8">
          <h2 class="text-xl font-bold text-neutral-900 mb-6">Book Your Free Demo</h2>
          <form class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Your Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone Number</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email Address</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
            </div>
            <div>
              <label for="trade" class="block text-sm font-medium text-neutral-700 mb-1">What trade are you in?</label>
              <select id="trade" name="trade" class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
                <option value="">Select your trade...</option>
                <option value="plumbing">Plumbing</option>
                <option value="electrical">Electrical</option>
                <option value="hvac">HVAC</option>
                <option value="building">Building / Construction</option>
                <option value="landscaping">Landscaping</option>
                <option value="roofing">Roofing</option>
                <option value="painting">Painting</option>
                <option value="cleaning">Cleaning</option>
                <option value="mechanical">Mechanical / Auto</option>
                <option value="property">Property Management</option>
                <option value="other">Other</option>
              </select>
            </div>
            <button type="submit" class="w-full px-6 py-3.5 text-base font-semibold text-white bg-primary rounded-lg hover:bg-primary-dark transition-colors">
              Book My Free Demo
            </button>
            <p class="text-xs text-neutral-500 text-center">No obligation. We'll be in touch within 24 hours.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
