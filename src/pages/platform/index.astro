---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Platform — All Features | PipeHQ"
  description="Explore the full PipeHQ platform: AI voice quoting, smart follow-up, scheduling, invoicing, review automation, AI receptionist, and more."
  canonicalUrl="/platform"
>
  <Header slot="header" />

  <section class="py-(--space-section-y) md:py-(--space-section-y-lg)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold text-neutral-900">The Complete Platform for Trade Businesses</h1>
      <p class="mt-4 text-lg text-neutral-600 max-w-2xl">Nine powerful AI-driven tools, one simple platform. Everything you need to win more jobs, get paid faster, and grow your business.</p>
      <!-- TODO: Feature cards linking to individual feature pages -->
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
