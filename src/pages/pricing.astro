---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/sections/FAQ.astro';
---

<BaseLayout
  title="Pricing — Simple, Transparent Plans | PipeHQ"
  description="PipeHQ offers simple, transparent pricing for trade businesses. No long-term contracts. No hidden fees. Cancel anytime."
  canonicalUrl="/pricing"
>
  <Header slot="header" />

  <section class="py-(--space-section-y) md:py-(--space-section-y-lg)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-neutral-900">Simple, Honest Pricing</h1>
        <p class="mt-4 text-lg text-neutral-600">No hidden fees. No long-term contracts. Cancel anytime.</p>
      </div>
      <!-- TODO: Pricing tiers / table -->
      <!-- TODO: Value stack for each tier -->
      <!-- TODO: CTA on each tier -->
    </div>
  </section>

  <FAQ headline="Pricing Questions" />

  <Footer slot="footer" />
</BaseLayout>
